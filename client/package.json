{
  "name": "onboardly-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "yarn build:server && concurrently -k -n client,server -c blue,green \"yarn dev:client\" \"yarn dev:server\"",
    "build:server": "dotnet build ../server/Onboardly.Server.csproj -nologo",
    "dev:client": "vite",
    "dev:server": "dotnet watch --project ../server/Onboardly.Server.csproj run",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "i18next": "^26.3.4",
    "localforage": "^1.10.0",
    "lodash-es": "^4.18.1",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
