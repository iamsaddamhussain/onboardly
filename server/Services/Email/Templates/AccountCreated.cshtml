@using Onboardly.Server.Services.Email
@using Onboardly.Server.Services.Email.Models
@model AccountCreatedEmailModel
@{
    Layout = "_Layout";
}

<h1 style="margin:0 0 16px;font-size:22px;color:@EmailTheme.Foreground;">Welcome, @Model.UserName!</h1>

<p style="margin:0 0 16px;">
    An account has been created for you at
    <strong>@Model.OrganizationName</strong>. You can now sign in and get started.
</p>

@if (!string.IsNullOrEmpty(Model.TemporaryPassword))
{
    <p style="margin:0 0 8px;">Use the temporary password below to sign in, then change it from your profile:</p>
    <p style="margin:0 0 20px;">
        <span style="display:inline-block;padding:10px 16px;background-color:@EmailTheme.Muted;border:1px solid @EmailTheme.Border;font-family:monospace;font-size:15px;">
            @Model.TemporaryPassword
        </span>
    </p>
}
else if (!string.IsNullOrEmpty(Model.PasswordSetupUrl))
{
    <p style="margin:0 0 20px;">
        To finish setting up your account, please set your password:
        <a href="@Model.PasswordSetupUrl" style="color:@Model.PrimaryColor;">Set your password</a>.
    </p>
}

<p style="margin:24px 0;">
    <a href="@Model.LoginUrl"
       style="display:inline-block;padding:12px 24px;background-color:@Model.PrimaryColor;color:@EmailTheme.PrimaryForeground;text-decoration:none;font-weight:bold;">
        Sign in
    </a>
</p>

<p style="margin:0;font-size:13px;color:@EmailTheme.MutedForeground;">
    If the button doesn't work, copy and paste this link into your browser:<br />
    <a href="@Model.LoginUrl" style="color:@Model.PrimaryColor;">@Model.LoginUrl</a>
</p>
