@using Onboardly.Server.Services.Email.Models
@model AccountCreatedEmailModel
@{
    Layout = "_Layout";
}

<h1 class="email-h1">Welcome, @Model.UserName!</h1>

<p class="email-p">
    An account has been created for you at
    <strong>@Model.OrganizationName</strong>. You can now sign in and get started.
</p>

@if (!string.IsNullOrEmpty(Model.TemporaryPassword))
{
    <p class="email-p">Use the temporary password below to sign in, then change it from your profile:</p>
    <p class="email-note">
        <span class="email-code">@Model.TemporaryPassword</span>
    </p>
}
else if (!string.IsNullOrEmpty(Model.PasswordSetupUrl))
{
    <p class="email-note">
        To finish setting up your account, please set your password:
        <a href="@Model.PasswordSetupUrl" class="brand-link">Set your password</a>.
    </p>
}

<p style="margin:24px 0;">
    <a href="@Model.LoginUrl" class="email-button brand-bg brand-fg">Sign in</a>
</p>

<p class="email-muted">
    If the button doesn't work, copy and paste this link into your browser:<br />
    <a href="@Model.LoginUrl" class="brand-link">@Model.LoginUrl</a>
</p>
