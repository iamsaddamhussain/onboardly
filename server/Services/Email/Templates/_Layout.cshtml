@model Onboardly.Server.Services.Email.Models.IEmailBrandingModel
@using Onboardly.Server.Services.Email
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.CompanyName</title>
    <style>
        @Raw(EmailStyles.Css)
        /* Brandable primary — can vary per organization. */
        .brand-bg { background-color: @Model.PrimaryColor; }
        .brand-link { color: @Model.PrimaryColor; }
    </style>
</head>
<body>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="email-wrapper">
        <tr>
            <td align="center">
                <table role="presentation" width="600" cellpadding="0" cellspacing="0" class="email-card">
                    <!-- Branding header -->
                    <tr>
                        <td class="email-header brand-bg" align="left">
                            @if (!string.IsNullOrEmpty(Model.LogoUrl))
                            {
                                <img src="@Model.LogoUrl" alt="@Model.CompanyName" height="32" style="height:32px;display:block;border:0;" />
                            }
                            else
                            {
                                <span class="email-header-title brand-fg">@Model.CompanyName</span>
                            }
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td class="email-body">
                            @RenderBody()
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td class="email-footer">
                            &copy; @DateTime.UtcNow.Year @Model.CompanyName. This is an automated message, please do not reply.
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
