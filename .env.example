# Copy this file to ".env" on the home server (next to docker-compose.yml).
# Docker Compose loads it automatically. Never commit the real .env.

# Postgres password (used by both the db and the server connection string)
DB_PASSWORD=change-me

# Images to run — replace <owner> with your lowercase GitHub owner/repo.
# The CI deploy job sets these automatically; only needed for manual runs.
SERVER_IMAGE=ghcr.io/iamsaddamhussain/onboardly-server:latest
CLIENT_IMAGE=ghcr.io/iamsaddamhussain/onboardly-client:latest
